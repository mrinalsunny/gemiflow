{
  "name": "gemiflow",
  "version": "3.10.46",
  "description": "GemiFlow - Enterprise AI agent orchestration for Gemini CLI. Deploy 60+ specialized agents in coordinated swarms with self-learning, fault-tolerant consensus, vector memory, and MCP integration",
  "main": "dist/index.js",
  "type": "module",
  "workspaces": [
    "v3/@gemiflow/*",
    "v3/plugins/*"
  ],
  "bin": {
    "gemiflow": "./bin/cli.js"
  },
  "homepage": "https://github.com/mrinalsunny/gemiflow#readme",
  "bugs": {
    "url": "https://github.com/mrinalsunny/gemiflow/issues",
    "email": "mrinalsunny@gmail.com"
  },
  "funding": {
    "type": "github",
    "url": "https://github.com/sponsors/mrinalsunny"
  },
  "files": [
    "bin/**",
    "v3/@gemiflow/cli/bin/**",
    "v3/@gemiflow/cli/dist/**/*.js",
    "v3/@gemiflow/cli/dist/**/*.d.ts",
    "!v3/@gemiflow/cli/dist/**/*.map",
    "v3/@gemiflow/cli/package.json",
    "v3/@gemiflow/shared/dist/**/*.js",
    "v3/@gemiflow/shared/dist/**/*.d.ts",
    "!v3/@gemiflow/shared/dist/**/*.map",
    "v3/@gemiflow/shared/package.json",
    "v3/@gemiflow/guidance/dist/**/*.js",
    "v3/@gemiflow/guidance/dist/**/*.d.ts",
    "!v3/@gemiflow/guidance/dist/**/*.map",
    "v3/@gemiflow/guidance/package.json",
    ".claude-plugin/**",
    ".gemiflow/**",
    "!.gemiflow/**/*.db",
    "!.gemiflow/**/*.map",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc",
    "build:ts": "cd v3/@gemiflow/cli && npm run build || true",
    "test": "vitest",
    "test:ui": "vitest --ui",
    "test:security": "vitest run v3/__tests__/security/",
    "lint": "cd v3/@gemiflow/cli && npm run lint || true",
    "security:audit": "npm audit --audit-level high",
    "security:fix": "npm audit fix",
    "security:test": "npm run test:security",
    "v3:domains": "npm run build:domains",
    "v3:swarm": "npm run start:swarm",
    "v3:security": "npm run security:audit && npm run security:test"
  },
  "dependencies": {
    "@noble/ed25519": "^2.1.0",
    "@ruvector/rabitq-wasm": "^0.1.0",
    "semver": "^7.6.0",
    "zod": "^3.22.4",
    "@gemiflow/cli-core": "workspace:*",
    "@gemiflow/mcp": "workspace:*",
    "@gemiflow/neural": "workspace:*",
    "@gemiflow/shared": "workspace:*"
  },
  "optionalDependencies": {
    "@ruvector/attention": "^0.1.3",
    "@ruvector/core": "^0.1.30",
    "@ruvector/router": "^0.1.30",
    "@ruvector/router-linux-x64-gnu": "^0.1.30",
    "@ruvector/sona": "^0.1.5",
    "agentdb": "^3.0.0-alpha.16",
    "agentic-flow": "^2.0.13",
    "@gemiflow/gemini": "workspace:*",
    "@gemiflow/plugin-gastown-bridge": "workspace:*"
  },
  "overrides": {
    "ruvector": "^0.2.27",
    "better-sqlite3": ">=12.8.0",
    "hono": ">=4.11.4",
    "@ruvector/rvf-wasm": "0.1.5",
    "@hono/node-server": ">=1.19.10",
    "flatted": ">=3.4.0",
    "tar": ">=7.5.11",
    "picomatch": ">=4.0.3",
    "path-to-regexp": ">=8.2.1",
    "undici": ">=7.18.0",
    "minimatch": ">=10.0.0",
    "@isaacs/brace-expansion": ">=5.0.1",
    "cacache": ">=20.0.0",
    "make-fetch-happen": ">=15.0.0",
    "express-rate-limit": ">=8.4.1",
    "express": ">=4.22.2",
    "qs": ">=6.15.2",
    "protobufjs": ">=8.2.0",
    "uuid": ">=14.0.0",
    "@opentelemetry/core": "1.25.1",
    "@opentelemetry/resources": "1.25.1",
    "@opentelemetry/sdk-trace-base": "1.25.1",
    "@opentelemetry/sdk-node": ">=0.218.0",
    "@opentelemetry/auto-instrumentations-node": ">=0.75.0",
    "@opentelemetry/exporter-prometheus": ">=0.217.0",
    "axios": ">=1.13.2",
    "fast-uri": ">=3.1.0",
    "vite": ">=6.4.6",
    "ws": ">=8.18.4"
  },
  "devDependencies": {
    "@openai/gemini": "^0.98.0",
    "@types/bcrypt": "^5.0.2",
    "@types/node": "^20.0.0",
    "eslint": "^8.0.0",
    "tsx": "^4.21.0",
    "typescript": "^5.0.0",
    "vitest": "^1.0.0"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/mrinalsunny/gemiflow.git"
  },
  "keywords": [
    "gemiflow",
    "gemini",
    "gemini-cli",
    "google",
    "ai",
    "ai-agents",
    "multi-agent",
    "agent-orchestration",
    "swarm-intelligence",
    "swarm",
    "mcp",
    "model-context-protocol",
    "llm",
    "large-language-model",
    "gpt",
    "chatgpt",
    "automation",
    "workflow",
    "orchestration",
    "cli",
    "developer-tools",
    "devtools",
    "coding-assistant",
    "code-generation",
    "enterprise",
    "vector-database",
    "embeddings",
    "machine-learning",
    "neural-network",
    "hive-mind",
    "distributed-systems",
    "consensus",
    "self-learning"
  ],
  "author": {
    "name": "mrinalsunny",
    "email": "mrinalsunny@gmail.com",
    "url": "https://github.com/mrinalsunny"
  },
  "contributors": [
    "mrinalsunny <mrinalsunny@gmail.com> (https://github.com/mrinalsunny)"
  ],
  "license": "MIT",
  "publishConfig": {
    "access": "public",
    "tag": "latest"
  }
}
