{
  "name": "@gemiflow/cli-core",
  "version": "3.7.0-alpha.5",
  "description": "Lightweight core CLI surface for GemiFlow — memory + hooks commands only. Designed to load fast on cold npx cache (<5s) so plugin skills don't race the 30s MCP-startup timeout. The full @gemiflow/cli metapackage lazy-loads everything else on top of this core.",
  "type": "module",
  "main": "dist/src/index.js",
  "types": "dist/src/index.d.ts",
  "bin": {
    "gemiflow-core": "dist/src/index.js"
  },
  "exports": {
    ".": "./dist/src/index.js",
    "./output": "./dist/src/output.js",
    "./types": "./dist/src/types.js",
    "./memory": "./dist/src/memory/backend.js",
    "./memory/json-backend": "./dist/src/memory/json-backend.js",
    "./commands/memory": "./dist/src/commands/memory.js",
    "./mcp-tools": "./dist/src/mcp-tools/index.js",
    "./mcp-tools/types": "./dist/src/mcp-tools/types.js",
    "./mcp-tools/validate-input": "./dist/src/mcp-tools/validate-input.js",
    "./mcp-tools/memory-defs": "./dist/src/mcp-tools/memory-defs.js",
    "./mcp-tools/hooks-defs": "./dist/src/mcp-tools/hooks-defs.js"
  },
  "scripts": {
    "build": "tsc",
    "test": "vitest run"
  },
  "files": [
    "dist/",
    "README.md",
    "LICENSE"
  ],
  "keywords": [
    "gemiflow",
    "cli",
    "core",
    "lite",
    "lazy-load",
    "mcp",
    "memory",
    "hooks"
  ],
  "author": {
    "name": "mrinalsunny",
    "url": "https://github.com/mrinalsunny"
  },
  "license": "MIT",
  "homepage": "https://github.com/mrinalsunny/gemiflow",
  "repository": {
    "type": "git",
    "url": "https://github.com/mrinalsunny/gemiflow.git",
    "directory": "v3/@gemiflow/cli-core"
  },
  "publishConfig": {
    "access": "public",
    "tag": "alpha"
  }
}
