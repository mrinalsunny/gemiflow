        "optimize": { "interval": "30m", "priority": "high" },
        "consolidate": { "interval": "2h", "priority": "low" },
        "document": { "interval": "1h", "priority": "normal" },
        "deepdive": { "interval": "4h", "priority": "normal" },
        "ultralearn": { "interval": "1h", "priority": "normal" }
      }
    },
    "learning": {
