    "security": {
      "autoScan": true,
      "scanOnEdit": true,
      "cveCheck": true,
      "threatModel": true
    }
  },
  "agents": {
    "source": ".gemiflow4gemini/agents",
    "customAgents": []
  },
  "skills": {
    "source": ".gemiflow4gemini/commands",
    "enabled": true
  },
  "statusLine": {
    "type": "command",
    "command": "sh -c 'exec node \"${CLAUDE_PROJECT_DIR:-.}/.gemiflow4gemini/helpers/statusline.cjs\"'"
  },
  "mcpServers": {
    "gemiflow4gemini": {
      "command": "npx",
      "args": [
        "-y",
        "gemiflow@latest",
        "mcp",
        "start"
      ]
